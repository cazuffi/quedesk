{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "widget",
  "description": "Today widget and quick capture windows",
  "windows": ["today-widget", "quick-capture"],
  "permissions": [
    "core:default",
    "core:event:allow-emit",
    "core:event:allow-listen",
    "core:window:allow-hide",
    "allow-show-main-window",
    "sql:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-close"
  ]
}
